# ─────────────────────────────────────────────
#  RAG API – Environment Configuration
# ─────────────────────────────────────────────

# LLM Provider – Groq (free tier, open-source models)
# Get your key at: https://console.groq.com
GROQ_API_KEY="your_api_key_here"

# LLM Model (Groq-hosted open-source models)
LLM_MODEL=llama3-70b-8192

# Embedding model (runs locally, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking config
CHUNK_SIZE=400
CHUNK_OVERLAP=80
TOP_K_RESULTS=5

# Rate limiting (requests per minute per IP)
RATE_LIMIT=20

# File upload config (bytes)
MAX_FILE_SIZE=10485760

# Storage paths
UPLOAD_DIR=uploads
FAISS_INDEX_PATH=vector_store/faiss_index
METADATA_PATH=vector_store/metadata.json
LOG_FILE=logs/rag.log
